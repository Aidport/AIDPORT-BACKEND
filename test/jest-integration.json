{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "maxWorkers": 1,
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "testEnvironment": "node",
  "testRegex": ".integration-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testTimeout": 60000
}
