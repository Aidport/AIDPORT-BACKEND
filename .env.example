# Server
PORT=3000
# Set to false to disable Swagger UI at /api (e.g. production)
SWAGGER_ENABLED=true
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Browser CORS: comma-separated origins. Omit to use production defaults (Aidport Vercel admin + web only).
# For local dev: CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# CORS_ORIGINS=https://admin-zeta-eight-76.vercel.app,https://aidport-web.vercel.app

# Rate limiting (@nestjs/throttler; in-memory — use one instance or Redis storage for multi-node)
# Global: THROTTLE_GLOBAL_LIMIT requests per THROTTLE_TTL_MS per client IP (all routes except / and /health).
# Login: THROTTLE_LOGIN_LIMIT per minute per account email on POST /auth/login and /auth/login/agent.
# THROTTLE_TTL_MS=60000
# THROTTLE_GLOBAL_LIMIT=100
# THROTTLE_LOGIN_LIMIT=5
# THROTTLE_DISABLED=true
# Behind nginx/ALB, set so req.ip / X-Forwarded-For are correct:
# TRUST_PROXY=true

# Cloudinary (uploads use access_mode=public — delivery URLs work without login like normal public files)
# PDF: in console, Settings → Security → enable "Allow delivery of PDF and ZIP files" (required on Free tier
# or PDF links return errors). Settings → Upload → PDF should be allowed for uploads.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=aidport

# MongoDB
MONGODB_URI=mongodb://localhost:27017/aidport

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# httpOnly JWT cookie (login/signup set it; passport-jwt reads cookie OR Authorization Bearer)
# JWT_COOKIE_NAME=access_token
# Cross-site SPA + API on different domains often needs: JWT_COOKIE_SAMESITE=none and JWT_COOKIE_SECURE=true
# JWT_COOKIE_SAMESITE=lax
# JWT_COOKIE_SECURE=
# JWT_COOKIE_DOMAIN=

# Email — 1) Gmail OAuth2  2) SMTP user/password (e.g. Gmail app password)
# auto (default): OAuth if all Gmail OAuth vars are set, else SMTP.
# If OAuth broke but SMTP works: EMAIL_TRANSPORT=smtp
# EMAIL_TRANSPORT=auto|smtp|oauth
# Skip startup verify (OAuth getAccessToken / SMTP verify): EMAIL_VERIFY_ON_BOOT=false

# Gmail via OAuth2 + Nodemailer (googleapis) — OAuth Playground refresh token
# Do not set SMTP_PASS when using this path.
# GMAIL_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=GOCSPX-xxxxx
# GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
# GMAIL_REFRESH_TOKEN=1//0g...
# GMAIL_USER=youraccount@gmail.com
# GMAIL_FROM=Aidport <youraccount@gmail.com>

# Aliases (same as GMAIL_* above — supported by EmailService)
# CLIENT_ID=
# CLIENT_SECRET=
# REDIRECT_URI=
# REFRESH_TOKEN=
# GMAIL_NAME=

# Gmail / SMTP with app password — omit Gmail OAuth vars to use this.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@aidport.com
